<witos>
     <append xpath="/entity_classes">
        <entity_class name="Airplane">
          <property name="Class" value="WitosRoot.EntityAirplanePro,suspension"/>
          <property name="Tags" value="vehicle,usesGas"/>
          <property name="Parent" value="Cars"/>
          <property name="Prefab" value="#@modfolder:Resources/Airplane.unity3d?Airplane"/>
          <property name="ModelType" value="Standard"/>
          <property name="SurfaceCategory" value="metal"/>
          <property name="IgnoreTrigger" value="true"/>
          <property name="LootList" value="vehicleGyrocopter"/>
          <property name="IsEnemyEntity" value="false"/>
          <property name="RotateToGround" value="true"/>
          <property name="Faction" value="none"/>
          <property name="MapIcon" value="Airplanemap"/>
          <property name="NavObject" value="Airplanemap"/>
		  <property class="Explosion">
			<property name="ParticleIndex" value="28"/>
			<property name="RadiusBlocks" value="5"/>
			<property name="RadiusEntities" value="5"/>
			<property name="BlockDamage" value="100"/>
			<property name="EntityDamage" value="100"/>
		  </property>

        </entity_class>
      </append>

</witos>
